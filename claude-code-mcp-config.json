{
  "mcpServers": {
    "sdl-mcp": {
      "command": "npx",
      "args": [
        "--yes",
        "sdl-mcp@latest",
        "serve",
        "--stdio"
      ],
      "env": {
        "SDL_CONFIG": "/root/.config/sdl-mcp/sdlmcp.config.json",
        "_comment_env": "Alternative: Set SDL_CONFIG_PATH if you prefer environment variable name"
      }
    }
  }
}